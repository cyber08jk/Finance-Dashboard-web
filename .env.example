# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database - Supabase (Transaction Pooler)
# For local development, you can use local PostgreSQL or Supabase
# For production (Vercel), use Supabase Transaction Pooler URL
# Get from: Supabase Dashboard → Settings → Database → Connection String → URI → Transaction
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Database SSL Settings
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# CORS Configuration
# For single project deployment on Vercel, use * or your domain
# Local development: http://localhost:3001
# Production: https://your-project.vercel.app or *
CORS_ORIGINS=http://localhost:3001

# JWT Configuration
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-chars
JWT_EXPIRATION=7d

# Application Info
APP_NAME=Finance Dashboard
APP_VERSION=1.0.0

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Note: Frontend variables should be in frontend/.env.local
# These are here for reference only

# For single project deployment (same domain):
# NEXT_PUBLIC_API_URL=/

# For local development (separate ports):
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================
# PRODUCTION DEPLOYMENT (Vercel)
# ============================================
# Add these in Vercel Dashboard → Settings → Environment Variables:
#
# NODE_ENV=production
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# CORS_ORIGINS=*
# JWT_SECRET=your-production-secret-min-32-chars
# JWT_EXPIRATION=7d
# APP_NAME=Finance Dashboard
# APP_VERSION=1.0.0
# NEXT_PUBLIC_API_URL=/
# NEXT_PUBLIC_APP_NAME=Finance Dashboard
# NEXT_PUBLIC_APP_VERSION=1.0.0
