# Server
PORT=3000
NODE_ENV=production

# Supabase Project Details
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Database - Supabase (Transaction Pooler URI)
# URL-encode special characters in password if needed.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# CORS
CORS_ORIGINS=https://your-app.vercel.app

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRATION=7d

# App
APP_NAME=Finance Dashboard Backend
APP_VERSION=1.0.0
