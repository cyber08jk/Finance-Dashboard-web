# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# API Configuration
# For single project deployment on Vercel (RECOMMENDED):
NEXT_PUBLIC_API_URL=/

# For local development with backend on different port:
# NEXT_PUBLIC_API_URL=http://localhost:3000

# For separate project deployment:
# NEXT_PUBLIC_API_URL=https://your-backend-url.vercel.app

# Application Info
NEXT_PUBLIC_APP_NAME=Finance Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# OPTIONAL SERVICES
# ============================================

# Analytics (Google Analytics, Plausible, etc.)
# NEXT_PUBLIC_GA_ID=

# Error Tracking (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=

# Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ============================================
# NOTES
# ============================================
# 
# Single Project Deployment (Recommended):
# - Set NEXT_PUBLIC_API_URL=/
# - Frontend and backend on same domain
# - No CORS issues
#
# Local Development:
# - Set NEXT_PUBLIC_API_URL=http://localhost:3000
# - Backend runs on port 3000
# - Frontend runs on port 3001
#
# Separate Projects Deployment:
# - Set NEXT_PUBLIC_API_URL=https://your-backend-url.vercel.app
# - Frontend and backend on different domains
# - Need to configure CORS on backend
